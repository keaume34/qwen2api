# qwen2api environment example. Copy to .env and fill in.

# Listen port
QWEN2API_PORT=5001

# Comma-separated client API keys. Empty = unauthenticated (NOT recommended).
QWEN2API_API_KEY=sk-change-me

# Comma-separated Qwen bearer tokens (from localStorage.getItem("token"))
QWEN2API_TOKENS=

# Optional upstream overrides
# QWEN2API_BASE_URL=https://chat.qwen.ai
# QWEN2API_SSXMOD_ITNA=
# QWEN2API_SSXMOD_ITNA2=
# QWEN2API_USER_AGENT=
# QWEN2API_TIMEOUT_SECONDS=120
# QWEN2API_COOLDOWN_SECONDS=60
# QWEN2API_LOG_LEVEL=info
